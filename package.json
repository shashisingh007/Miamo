{
  "name": "miamo",
  "version": "3.0.0",
  "private": true,
  "description": "Miamo — Next-generation dating & social platform",
  "scripts": {
    "start": "bash scripts/start-services.sh local start",
    "stop": "bash scripts/start-services.sh local stop",
    "restart": "bash scripts/start-services.sh local restart",
    "status": "bash scripts/start-services.sh local status",
    "test": "vitest run --config vitest.fast.config.ts",
    "test:full": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:python": "python3 scripts/test-all.py",
    "typecheck": "node scripts/typecheck.mjs",
    "typecheck:shared": "cd services/shared && npx tsc --noEmit -p tsconfig.json",
    "logs": "bash scripts/start-services.sh local logs",
    "docker:up": "bash scripts/start-services.sh docker up",
    "docker:down": "bash scripts/start-services.sh docker down",
    "docker:status": "bash scripts/start-services.sh docker status",
    "k8s:dev": "bash scripts/start-services.sh k8s deploy dev",
    "k8s:staging": "bash scripts/start-services.sh k8s deploy staging",
    "k8s:prod": "bash scripts/start-services.sh k8s deploy prod",
    "db:migrate": "cd services/shared && npx prisma migrate dev",
    "db:push": "cd services/shared && npx prisma db push",
    "db:seed": "cd services/shared && npx prisma db seed",
    "db:studio": "cd services/shared && npx prisma studio",
    "setup": "bash scripts/setup.sh",
    "prepare": "husky"
  },
  "keywords": [
    "dating",
    "social",
    "microservices",
    "nextjs",
    "express",
    "prisma"
  ],
  "author": "Miamo Team",
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/supertest": "6.0.3",
    "@vitest/coverage-v8": "2.1.9",
    "husky": "9.1.7",
    "lint-staged": "15.5.2",
    "supertest": "7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "2.1.9"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,yml,yaml}": []
  }
}
