// ─── Miamo Database Schema ─────────────────────────────
// PostgreSQL + Prisma ORM — Full MVP Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ─────────────────────────────────────
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  displayName   String
  username      String    @unique
  miamoId       String    @unique
  verified      Boolean   @default(false)
  active        Boolean   @default(true)
  deactivated   Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  profile       Profile?
  settings      Settings?
  privacySettings PrivacySettings?
  photos        ProfilePhoto[]
  prompts       ProfilePrompt[]
  interests     ProfileInterest[]

  sentLikes       Like[]          @relation("SentLikes")
  receivedLikes   Like[]          @relation("ReceivedLikes")
  sentRequests    MatchRequest[]  @relation("SentRequests")
  receivedRequests MatchRequest[] @relation("ReceivedRequests")
  matchesAsUser1  Match[]         @relation("MatchUser1")
  matchesAsUser2  Match[]         @relation("MatchUser2")
  sentMessages    Message[]       @relation("SentMessages")
  chatsAsUser1    Chat[]          @relation("ChatUser1")
  chatsAsUser2    Chat[]          @relation("ChatUser2")

  beatsAsUser1    Beat[]          @relation("BeatUser1")
  beatsAsUser2    Beat[]          @relation("BeatUser2")
  beatEvents      BeatEvent[]

  feedPosts       FeedPost[]
  feedComments    FeedComment[]
  feedReactions   FeedReaction[]

  stories         Story[]
  storyViews      StoryView[]

  videos          Video[]
  videoComments   VideoComment[]
  videoReactions  VideoReaction[]

  creativityItems  CreativityItem[]
  creativityViews  CreativityView[]
  creativityReactions CreativityReaction[]
  creativityComments  CreativityComment[]

  searchLogs      SearchLog[]
  sentReports     Report[]        @relation("Reporter")
  receivedReports Report[]        @relation("Reported")
  sentBlocks      Block[]         @relation("Blocker")
  receivedBlocks  Block[]         @relation("Blocked")
  notifications   Notification[]
  auditLogs       AuditLog[]

  sentMoves       MiamoMove[]     @relation("SentMoves")
  receivedMoves   MiamoMove[]     @relation("ReceivedMoves")
  discoverFilter  DiscoverFilter?
  matchFeedbackGiven    MatchFeedback[] @relation("FeedbackGiver")
  matchFeedbackReceived MatchFeedback[] @relation("FeedbackTarget")

  @@index([email])
  @@index([username])
  @@index([miamoId])
}

model Profile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  age             Int
  gender          String
  city            String
  profession      String
  bio             String   @default("")
  datingIntent    String   @default("casual")
  seriousMode     Boolean  @default(false)
  profileScore    Int      @default(30)
  online          Boolean  @default(false)
  lastActive      DateTime @default(now())
  avatarGradient  String   @default("from-lavender-400 to-violet-deep")

  // Lifestyle & identity fields
  height          Int?                 // cm
  sexuality       String   @default("straight") // straight | gay | lesbian | bisexual | pansexual | asexual | queer | other
  lookingFor      String   @default("open")     // long-term | short-term | casual | marriage | friendship | open
  smoking         String   @default("never")    // never | sometimes | regularly
  drinking        String   @default("socially") // never | socially | regularly
  exercise        String   @default("sometimes") // never | sometimes | active | very-active
  education       String   @default("")          // high-school | bachelors | masters | phd | other
  religion        String   @default("")
  zodiac          String   @default("")
  languages       String   @default("")          // comma-separated
  pets            String   @default("")           // none | dog | cat | both | other
  children        String   @default("")           // none | have | want | maybe

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([city])
  @@index([gender])
  @@index([datingIntent])
  @@index([seriousMode])
  @@index([sexuality])
  @@index([lookingFor])
  @@index([height])
}

model ProfilePhoto {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url       String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([userId])
}

model ProfilePrompt {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question  String
  answer    String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([userId])
}

model ProfileInterest {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([name])
}

// ─── Settings ─────────────────────────────────────────
model Settings {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme            String   @default("dark")       // dark | light | system | lavender
  accentColor      String   @default("#A78BFA")
  reduceMotion     Boolean  @default(false)
  highContrast     Boolean  @default(false)
  readReceipts     Boolean  @default(true)
  typingIndicator  Boolean  @default(true)
  onlineStatus     Boolean  @default(true)
  lastActiveVisible Boolean @default(true)
  whoCanMessage    String   @default("matches")    // everyone | matches | nobody
  whoCanSendMedia  String   @default("matches")
  whoCanStartBeat  String   @default("matches")
  whoCanBroadcast  String   @default("matches")
  whoCanVoiceCall  String   @default("matches")
  whoCanVideoCall  String   @default("matches")
  storyVisibility  String   @default("everyone")   // everyone | matches | nobody
  feedVisibility   String   @default("everyone")
  videoVisibility  String   @default("everyone")
  creativityVisibility String @default("everyone")
  notificationsEnabled Boolean @default(true)
  beatReminders    Boolean  @default(true)
  messageNotifications Boolean @default(true)
  storyNotifications Boolean @default(true)
  privacyMode      Boolean  @default(false)
  invisibleMode    Boolean  @default(false)
  seriousModeEnabled Boolean @default(false)
  aiPersonalization Boolean @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model PrivacySettings {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileVisible   Boolean  @default(true)
  searchable       Boolean  @default(true)
  miamoIdSearchable Boolean @default(true)
  nameSearchable   Boolean  @default(true)
  citySearchable   Boolean  @default(true)
  hideExactCity    Boolean  @default(false)
  showApproxCity   Boolean  @default(true)
  disableSearch    Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ─── Likes & Matching ────────────────────────────────
model Like {
  id         String   @id @default(uuid())
  fromUserId String
  toUserId   String
  fromUser   User     @relation("SentLikes", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser     User     @relation("ReceivedLikes", fields: [toUserId], references: [id], onDelete: Cascade)
  targetType String   @default("profile") // profile | photo | prompt | post | video | story | creativity
  targetId   String?
  createdAt  DateTime @default(now())

  @@unique([fromUserId, toUserId, targetType, targetId])
  @@index([toUserId])
}

model MatchRequest {
  id           String   @id @default(uuid())
  fromUserId   String
  toUserId     String
  fromUser     User     @relation("SentRequests", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser       User     @relation("ReceivedRequests", fields: [toUserId], references: [id], onDelete: Cascade)
  type         String   @default("comment") // like | comment | question | compliment | emoji | voice
  message      String   @default("")
  targetType   String   @default("profile") // profile | photo | prompt | post | video | story | creativity
  targetId     String?
  status       String   @default("pending") // pending | accepted | rejected
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([fromUserId, toUserId])
  @@index([toUserId, status])
}

model Match {
  id          String   @id @default(uuid())
  user1Id     String
  user2Id     String
  user1       User     @relation("MatchUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2       User     @relation("MatchUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  active      Boolean  @default(true)
  favorite1   Boolean  @default(false) // user1 favorited
  favorite2   Boolean  @default(false) // user2 favorited
  pinned1     Boolean  @default(false) // user1 pinned
  pinned2     Boolean  @default(false) // user2 pinned
  createdAt   DateTime @default(now())

  chat        Chat?
  feedback    MatchFeedback[]

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
}

// ─── Match Feedback (unmatch/report reasons for algorithm) ──
model MatchFeedback {
  id          String   @id @default(uuid())
  matchId     String
  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId      String   // who gave the feedback
  user        User     @relation("FeedbackGiver", fields: [userId], references: [id], onDelete: Cascade)
  targetUserId String  // who it's about
  targetUser  User     @relation("FeedbackTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  type        String   // unmatch | report
  reason      String   // predefined reason code
  details     String   @default("") // free-text elaboration
  createdAt   DateTime @default(now())

  @@index([matchId])
  @@index([userId])
  @@index([targetUserId])
  @@index([reason])
  @@index([type])
}

// ─── Messages & Chats ────────────────────────────────
model Chat {
  id          String    @id @default(uuid())
  matchId     String    @unique
  match       Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user1Id     String
  user2Id     String
  user1       User      @relation("ChatUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2       User      @relation("ChatUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  pinned1     Boolean   @default(false) // pinned by user1
  pinned2     Boolean   @default(false)
  muted1      Boolean   @default(false)
  muted2      Boolean   @default(false)
  archived1   Boolean   @default(false)
  archived2   Boolean   @default(false)
  background  String    @default("default")
  theme       String    @default("default") // default | lavender
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  messages    Message[]

  @@index([user1Id])
  @@index([user2Id])
}

model Message {
  id            String    @id @default(uuid())
  chatId        String
  chat          Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId      String
  sender        User      @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  content       String
  type          String    @default("text") // text | image | voice | snap | system
  replyToId     String?
  replyTo       Message?  @relation("Replies", fields: [replyToId], references: [id])
  replies       Message[] @relation("Replies")
  reactions     String    @default("") // JSON array of {userId, emoji}
  read          Boolean   @default(false)
  deletedForAll Boolean   @default(false)
  deletedFor    String    @default("") // comma-separated userIds
  editedAt      DateTime?
  createdAt     DateTime  @default(now())

  @@index([chatId, createdAt])
  @@index([senderId])
}

// ─── Beats (Streaks) ─────────────────────────────────
model Beat {
  id         String     @id @default(uuid())
  user1Id    String
  user2Id    String
  user1      User       @relation("BeatUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2      User       @relation("BeatUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  count      Int        @default(0)
  state      String     @default("active") // active | weak | lost | archived
  lastUser1  DateTime?
  lastUser2  DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  events     BeatEvent[]

  @@unique([user1Id, user2Id])
  @@index([state])
}

model BeatEvent {
  id        String   @id @default(uuid())
  beatId    String
  beat      Beat     @relation(fields: [beatId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   @default("snap") // snap | text | mood | voice
  content   String   @default("")
  createdAt DateTime @default(now())

  @@index([beatId, createdAt])
}

// ─── Feed ────────────────────────────────────────────
model FeedPost {
  id         String   @id @default(uuid())
  authorId   String
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  type       String   @default("thought") // thought | image | video | date-idea | poll | mood | milestone
  content    String
  mediaUrl   String?
  visibility String   @default("everyone") // everyone | matches | private
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  comments   FeedComment[]
  reactions  FeedReaction[]

  @@index([authorId, createdAt])
  @@index([visibility])
}

model FeedComment {
  id        String   @id @default(uuid())
  postId    String
  post      FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
}

model FeedReaction {
  id        String   @id @default(uuid())
  postId    String
  post      FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   @default("like") // like | love | fire | haha | wow
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
}

// ─── Stories ─────────────────────────────────────────
model Story {
  id         String   @id @default(uuid())
  authorId   String
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  type       String   @default("photo") // photo | video | text
  content    String   @default("")
  mediaUrl   String?
  visibility String   @default("everyone")
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  views      StoryView[]

  @@index([authorId, createdAt])
  @@index([expiresAt])
}

model StoryView {
  id        String   @id @default(uuid())
  storyId   String
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  viewerId  String
  viewer    User     @relation(fields: [viewerId], references: [id], onDelete: Cascade)
  reaction  String?
  createdAt DateTime @default(now())

  @@unique([storyId, viewerId])
  @@index([storyId])
}

// ─── Videos ──────────────────────────────────────────
model Video {
  id          String   @id @default(uuid())
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  title       String
  description String   @default("")
  url         String   @default("")
  thumbnailUrl String  @default("")
  category    String   @default("general")
  visibility  String   @default("everyone")
  views       Int      @default(0)
  createdAt   DateTime @default(now())

  comments    VideoComment[]
  reactions   VideoReaction[]

  @@index([authorId])
  @@index([category])
  @@index([createdAt])
}

model VideoComment {
  id        String   @id @default(uuid())
  videoId   String
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([videoId, createdAt])
}

model VideoReaction {
  id        String   @id @default(uuid())
  videoId   String
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   @default("like")
  createdAt DateTime @default(now())

  @@unique([videoId, userId])
}

// ─── Creativity ──────────────────────────────────────
model CreativityCategory {
  id    String @id @default(uuid())
  name  String @unique
  icon  String @default("sparkles")
  color String @default("#A78BFA")
  items CreativityItem[]
}

model CreativityItem {
  id          String   @id @default(uuid())
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  categoryId  String
  category    CreativityCategory @relation(fields: [categoryId], references: [id])
  type        String   @default("text") // image | video | text | voice | carousel | project | performance | poem | date-idea
  title       String
  content     String
  mediaUrl    String?
  visibility  String   @default("everyone")
  featured    Boolean  @default(false)
  views       Int      @default(0)
  trendScore  Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reactions   CreativityReaction[]
  comments    CreativityComment[]
  viewRecords CreativityView[]

  @@index([authorId])
  @@index([categoryId])
  @@index([trendScore(sort: Desc)])
  @@index([createdAt])
}

model CreativityView {
  id        String         @id @default(uuid())
  itemId    String
  item      CreativityItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  viewerId  String
  viewer    User           @relation(fields: [viewerId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@unique([itemId, viewerId])
}

model CreativityReaction {
  id        String         @id @default(uuid())
  itemId    String
  item      CreativityItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String         @default("like")
  createdAt DateTime       @default(now())

  @@unique([itemId, userId])
}

model CreativityComment {
  id        String         @id @default(uuid())
  itemId    String
  item      CreativityItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  authorId  String
  author    User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime       @default(now())

  @@index([itemId, createdAt])
}

// ─── Trends ──────────────────────────────────────────
model Trend {
  id           String   @id @default(uuid())
  itemId       String
  itemType     String   // creativity | video | post
  category     String
  score        Float    @default(0)
  views        Int      @default(0)
  likes        Int      @default(0)
  comments     Int      @default(0)
  saves        Int      @default(0)
  shares       Int      @default(0)
  matchRequests Int     @default(0)
  rank         Int      @default(0)
  categoryRank Int      @default(0)
  calculatedAt DateTime @default(now())

  @@unique([itemId, itemType])
  @@index([score(sort: Desc)])
  @@index([category, categoryRank])
}

// ─── Search ──────────────────────────────────────────
model SearchLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  query     String
  type      String   @default("general") // user | city | interest | category
  results   Int      @default(0)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// ─── Safety ──────────────────────────────────────────
model Report {
  id           String   @id @default(uuid())
  reporterId   String
  reportedId   String
  reporter     User     @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reported     User     @relation("Reported", fields: [reportedId], references: [id], onDelete: Cascade)
  reason       String
  details      String   @default("")
  targetType   String   @default("user") // user | post | message | video | story | creativity
  targetId     String?
  status       String   @default("pending") // pending | reviewed | resolved | dismissed
  createdAt    DateTime @default(now())

  @@index([reportedId])
  @@index([status])
}

model Block {
  id         String   @id @default(uuid())
  blockerId  String
  blockedId  String
  blocker    User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked    User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

// ─── Notifications ───────────────────────────────────
model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // match | message | like | comment | beat | story | system
  title     String
  body      String
  data      String   @default("{}") // JSON payload
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read, createdAt])
}

// ─── Miamo Move (Hinge-style first moves) ───────────
model MiamoMove {
  id           String   @id @default(uuid())
  fromUserId   String
  toUserId     String
  fromUser     User     @relation("SentMoves", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser       User     @relation("ReceivedMoves", fields: [toUserId], references: [id], onDelete: Cascade)
  message      String   @default("")       // empty = blank move
  targetType   String   @default("profile") // profile | photo | prompt | post
  targetId     String?                      // specific content id
  status       String   @default("pending") // pending | accepted | rejected | expired
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([fromUserId, toUserId, targetType, targetId])
  @@index([toUserId, status])
  @@index([fromUserId, createdAt])
}

// ─── Discover Filters (persisted preferences) ───────
model DiscoverFilter {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  minAge         Int      @default(18)
  maxAge         Int      @default(99)
  minHeight      Int?     // cm
  maxHeight      Int?     // cm
  distance       Int      @default(50) // km
  city           String   @default("")
  genders        String   @default("") // comma-separated: male,female,nonbinary
  sexualities    String   @default("") // comma-separated filter
  lookingFor     String   @default("") // long-term,short-term,casual etc
  smoking        String   @default("") // never,sometimes,regularly
  drinking       String   @default("") // never,socially,regularly
  exercise       String   @default("") // never,sometimes,active,very-active
  education      String   @default("")
  religion       String   @default("")
  zodiac         String   @default("")
  pets           String   @default("")
  children       String   @default("")
  activeToday    Boolean  @default(false)
  newHere        Boolean  @default(false)   // registered < 7 days
  verified       Boolean  @default(false)
  hasPhotos      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── Audit Log ───────────────────────────────────────
model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  details   String   @default("{}")
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}
