# ─── Node / build outputs ────────────────────────────
**/node_modules
**/.next
**/dist
**/build
**/coverage
**/.turbo

# ─── Git + IDE ───────────────────────────────────────
.git
.gitignore
.github
.vscode
.idea
.claude

# ─── OS junk ─────────────────────────────────────────
.DS_Store
**/.DS_Store
Thumbs.db

# ─── Docker / compose (context is repo root, but images
# don't need the compose file baked in) ──────────────
docker-compose.yml
docker-compose*.yml

# ─── Tests, docs, samples ────────────────────────────
tests/
**/*.test.ts
**/*.spec.ts
**/__tests__/
docs/
*.md
CHANGELOG*
LICENSE*
README*

# ─── Infra (not needed inside any app image) ─────────
terraform/
k8s/
kubernetes/

# ─── Deploy scripts + tooling ────────────────────────
scripts/
tools/
.husky/

# ─── Mobile (Expo/RN — 580 MB, never in server images) ─
mobile/

# ─── Legacy / duplicate roots ────────────────────────
api/
packages/
web/            # duplicate of services/web

# ─── Secrets + logs + local state ────────────────────
*.log
.env
.env.*
!.env.example
.terraform/
*.tfstate*
*.tfplan
.expo/
**/.expo/

# ─── Assets served at runtime, but not needed for build
# (Next.js public/ is intentionally NOT ignored) ────
assets/
!services/web/public/
