# Force Unix line endings for shell scripts (Windows Git converts LF→CRLF otherwise)
*.sh        text eol=lf
*.ps1       text eol=crlf
*.yaml      text eol=lf
*.yml       text eol=lf
*.json      text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.css       text eol=lf
*.md        text eol=lf
Dockerfile  text eol=lf
*.Dockerfile text eol=lf
