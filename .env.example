# ─── Miamo Environment Variables ──────────────────────
NODE_ENV=development
PORT=3200
FRONTEND_URL=http://localhost:3100
API_URL=http://localhost:3200

# Database
DATABASE_URL=postgresql://miamo:miamo_dev_pass@localhost:5432/miamo_dev
POSTGRES_USER=miamo
POSTGRES_PASSWORD=miamo_dev_pass
POSTGRES_DB=miamo_dev

# Auth
JWT_SECRET=miamo-dev-jwt-secret-change-in-production-2026
JWT_REFRESH_SECRET=miamo-dev-refresh-secret-change-in-production-2026
COOKIE_SECRET=miamo-dev-cookie-secret

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Storage
STORAGE_PROVIDER=local
STORAGE_BUCKET=miamo-uploads
MAX_UPLOAD_SIZE_MB=10
