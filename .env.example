# ─── Miamo Environment Variables ────────────────────────
# Copy to `.env` and fill in real values for production deployments.
# In NODE_ENV=production every secret below is REQUIRED — startup will fail
# fast if any are missing.

# ─── Runtime ─────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ─── Secrets (REQUIRED IN PRODUCTION) ────────────────
# Generate strong values with: openssl rand -hex 32
JWT_SECRET=
JWT_REFRESH_SECRET=
INTERNAL_SERVICE_KEY=
# Used for AES-256-GCM message encryption. Rotating breaks decryption of
# existing ciphertexts — pick once per deployment and keep it stable.
ENCRYPTION_KEY=
ENCRYPTION_SALT=

# ─── Database ────────────────────────────────────────
DATABASE_URL=postgresql://miamo:miamo@localhost:5432/miamo?schema=public

# ─── Service URLs (override only for non-default topology) ───
GATEWAY_URL=http://localhost:3200
AUTH_SERVICE_URL=http://localhost:3201
USER_SERVICE_URL=http://localhost:3202
SOCIAL_SERVICE_URL=http://localhost:3203
MESSAGING_SERVICE_URL=http://localhost:3204
CONTENT_SERVICE_URL=http://localhost:3205
NOTIFICATION_SERVICE_URL=http://localhost:3206

# ─── Frontend / CORS ─────────────────────────────────
FRONTEND_URL=http://localhost:3100
# Comma-separated list of additional allowed origins (gateway CORS)
ALLOWED_ORIGINS=
# Set CORS_BYPASS=true in dev only to allow any origin
CORS_BYPASS=false

# ─── Next.js (frontend) ──────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3200
