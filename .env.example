# ─── Miamo Environment Variables ────────────────────────
# Copy to `.env` and fill in real values for production deployments.
# In NODE_ENV=production every secret below is REQUIRED — startup will fail
# fast if any are missing.

# ─── Runtime ─────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
# HOSTNAME — overrides default bind host on the per-service Express listeners.
HOSTNAME=0.0.0.0
# Per-service PORT — overrides the defaults baked into each server.ts (3200–3206 + 3260/3261).
# PORT=

# ─── Secrets (REQUIRED IN PRODUCTION) ────────────────
# Generate strong values with: openssl rand -hex 32
JWT_SECRET=
JWT_REFRESH_SECRET=
INTERNAL_SERVICE_KEY=
# Used for AES-256-GCM message encryption. Rotating breaks decryption of
# existing ciphertexts — pick once per deployment and keep it stable.
ENCRYPTION_KEY=
ENCRYPTION_SALT=
# HMAC-SHA256 secret for hashing userId → uidHash in the tracking pipeline.
# Rotating this re-keys every downstream tracking table.
TRACKING_HASH_SECRET=dev-only-tracking-hash-secret-change-me
# Salt for device fingerprint hashing (auth/users).
DEVICE_FP_SALT=miamo-default-salt

# ─── Database ────────────────────────────────────────
# These three are read by docker-compose to bootstrap Postgres and by all
# services via DATABASE_URL. POSTGRES_PASSWORD is REQUIRED (no default).
POSTGRES_USER=miamo
POSTGRES_PASSWORD=
POSTGRES_DB=miamo
DATABASE_URL=postgresql://miamo:miamo@localhost:5432/miamo?schema=public

# ─── Redis (tracking stream + caches) ─────────────────
# Required for ingest → tracking-worker. Set empty in tests.
REDIS_URL=

# ─── Service URLs (override only for non-default topology) ───
GATEWAY_URL=http://localhost:3200
AUTH_SERVICE_URL=http://localhost:3201
USER_SERVICE_URL=http://localhost:3202
SOCIAL_SERVICE_URL=http://localhost:3203
MESSAGING_SERVICE_URL=http://localhost:3204
CONTENT_SERVICE_URL=http://localhost:3205
NOTIFICATION_SERVICE_URL=http://localhost:3206
INGEST_SERVICE_URL=http://localhost:3260

# ─── Frontend / CORS ─────────────────────────────────
FRONTEND_URL=http://localhost:3100
# Comma-separated list of additional allowed origins (gateway + ingest CORS).
# Both gateway and ingest read this var; legacy CORS_ORIGIN is no longer honoured.
ALLOWED_ORIGINS=
# Set CORS_BYPASS=true in dev only to allow any origin
CORS_BYPASS=false

# ─── Auth providers (OAuth + OTP) ────────────────────
# Google Sign-In: server-side audience verification.
GOOGLE_CLIENT_ID=
# Apple Sign-In: server-side audience verification (iss=https://appleid.apple.com).
APPLE_CLIENT_ID=
# OTP delivery provider. Defaults to 'dev' (no-op log-only).
OTP_PROVIDER_EMAIL=dev
OTP_PROVIDER_SMS=dev
# Dev-only OTP peek endpoint. ALWAYS set to '0' or omit in production.
ALLOW_DEV_OTP_PEEK=0
# Dev-only auto-approve for verification submissions. Set to '0' in production.
AUTO_APPROVE_VERIFY=0
# 3rd-party email provider key (SendGrid). Required if OTP_PROVIDER_EMAIL=sendgrid.
SENDGRID_API_KEY=

# ─── Next.js (frontend) ──────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3200
NEXT_PUBLIC_SITE_URL=http://localhost:3100
NEXT_PUBLIC_TRACK_ENDPOINT=/api/v1/track
NEXT_PUBLIC_TRACKING_ENABLED=1
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_APPLE_CLIENT_ID=
NEXT_PUBLIC_APPLE_REDIRECT_URI=

# ─── Tracking pipeline (ingest → Redis Stream → worker) ─
# Master kill switch for tracking. When '1', ingest 204s every event and worker loops are off.
TRACKING_KILL=0
# Redis Stream key carrying raw events from ingest to worker.
TRACKING_STREAM_KEY=events:raw
# Consumer group name on the stream.
TRACKING_GROUP=rollup
# Stream MAXLEN cap — ring-buffer trim target.
TRACKING_STREAM_MAXLEN=10000000
# Worker XREADGROUP block timeout (ms).
TRACKING_READ_BLOCK_MS=2000
# Max events per XREADGROUP batch.
TRACKING_READ_COUNT=500
# Worker flush interval for batched DB writes (ms).
TRACKING_FLUSH_MS=5000
# When '1', the worker writes a denormalised TotalState row per uidHash.
TRACKING_TOTAL_STATE_ENABLED=0
# Tighten Node keep-alive on services behind LB (ms).
KEEP_ALIVE_TIMEOUT=

# ─── v3.6.0 Feature Flags (all default OFF) ──────────
# Toggle individual product features. '1' = on, anything else = off.
# v8 ranker (Discover): replace V4 scorer with V8.
ALGO_V8_DISCOVER_RANKER_ENABLED=0
# v8 fairness rerank: post-process Discover for Gini-floor fairness.
ALGO_V8_FAIRNESS_RERANK_ENABLED=0
# v4 batch workers — daily-match, enrich, compat, embed, feature, etc.
ALGO_V4_WORKERS_ENABLED=0
# v5 message suggestion dispatcher.
ALGO_V5_MESSAGE_SUGGEST_ENABLED=0
# v3.6 anti-ghost ledger writes from messaging.
FEATURE_ANTI_GHOST_ENABLED=0
# DTM family-brief masking: hide identity until the recipient opts in.
FEATURE_DTM_MASK_ENABLED=0
# Family-brief share endpoints (content service).
FEATURE_FAMILY_BRIEF_ENABLED=0
# Move v2 composer pipeline (content service).
FEATURE_MOVE_V2_ENABLED=0
# Voice fingerprint analytics (users service).
FEATURE_VOICE_FINGERPRINT_ENABLED=0
# Weekly Top match endpoint (social service).
FEATURE_WEEKLY_TOP_ENABLED=0
# Why-Explainer per-target rationale endpoint (social service).
FEATURE_WHY_EXPLAINER_ENABLED=0
# Intent-Right-Now inference loop (worker).
INTENT_INFERENCE_ENABLED=0
# Exposure scheduler loop (worker).
EXPOSURE_SCHEDULER_ENABLED=0
# Stable-match Top-10 Gale–Shapley loop (worker).
STABLE_MATCH_ENABLED=0
# Daily fairness audit loop (worker).
FAIRNESS_AUDIT_ENABLED=0
# Discover hard-filter pass on incompatible candidates (default ON in production).
# Set to '0' to disable the pre-rank filter; '1' or unset = on.
DISCOVER_PASS_HARDFILTER_ENABLED=1

# ─── Tracking worker tunables ────────────────────────
# Each worker loop has an interval (in ms) and may have batch/lookback knobs.
# Defaults below match the code (`process.env.X || N`).

# Intent inference (intentRightNow.ts).
INTENT_INFERENCE_TICK_MS=30000
INTENT_INFERENCE_BATCH_SIZE=200
INTENT_ACTIVE_WINDOW_MS=120000
INTENT_ACTIVITY_LOOKBACK_MS=1800000
INTENT_HOURLY_LOOKBACK_HOURS=1
INTENT_RECENT_WINDOW_MS=3600000
INTENT_RECENT_TICK_MS=300000
INTENT_MAX_RECENT_EVENTS=30

# Exposure scheduler.
EXPOSURE_SCHEDULER_INTERVAL_MS=300000
EXPOSURE_SCHEDULER_BATCH=200
EXPOSURE_SCHEDULER_LOOKBACK_HOURS=24
EXPOSURE_SCHEDULER_SURFACE=discover

# Stable-match Top-10.
STABLE_MATCH_INTERVAL_MS=600000
STABLE_MATCH_BATCH=200
STABLE_MATCH_TOP_K_OUT=10
STABLE_MATCH_TOP_K_PROPOSE=50
STABLE_MATCH_ACTIVE_WINDOW_DAYS=7
STABLE_MATCH_PASS_WINDOW_DAYS=30
STABLE_MATCH_MIN_INTERVAL_DAYS=6

# Fairness audit.
FAIRNESS_AUDIT_INTERVAL_MS=600000
FAIRNESS_AUDIT_LOOKBACK_DAYS=7
FAIRNESS_AUDIT_HOUR_UTC=2
FAIRNESS_AUDIT_EVENT=card.impression.50
FAIRNESS_AUDIT_GINI_ALERT=0.45
# System user id that the audit job impersonates when emitting alert events.
FAIRNESS_AUDIT_SYSTEM_USER_ID=

# Compatibility scoring loop.
COMPAT_INTERVAL_MS=900000
COMPAT_ACTIVE_LIMIT=200
COMPAT_CANDIDATES=50
COMPAT_TOPK=20
COMPAT_W_BEHAVIOR=0.25
COMPAT_W_CHRONO=0.35
COMPAT_W_PRIOR=0.4

# Enrichment loop (DTM, peak, cadence).
ENRICH_INTERVAL_MS=1800000
ENRICH_CADENCE_DAYS=14
ENRICH_DTM_DAYS=90
ENRICH_PEAK_DAYS=7
ENRICH_PEAK_TOP_N=6

# Embedding refresh loop.
EMBED_INTERVAL_MS=1800000
EMBED_BATCH=200

# Daily-match generator.
DAILY_MATCH_INTERVAL_MS=43200000
DAILY_MATCH_BATCH=200
DAILY_MATCH_POOL=50
DAILY_MATCH_MIN_SCORE=70
DAILY_MATCH_USER_DAYS=7

# Feature aggregator.
FEATURE_INTERVAL_MS=300000
FEATURE_BATCH=200

# Learner loop (online weight update).
LEARNER_LOOP_ENABLED=0
LEARNER_LOOP_INTERVAL_MS=600000
LEARNER_LOOP_BATCH=500
LEARNER_LOOP_LOOKBACK_DAYS=1
LEARNER_LOOP_SURFACE=discover

# Safety rollup loop.
SAFETY_ROLLUP_INTERVAL_MS=300000
SAFETY_ROLLUP_LOOKBACK_DAYS=2

# First-move outcome attribution.
FIRST_MOVE_OUTCOME_ENABLED=0
FIRST_MOVE_OUTCOME_INTERVAL_MS=1800000
FIRST_MOVE_OUTCOME_LOOKBACK_HOURS=25

# Session summary loop.
SESSION_SUMMARY_ENABLED=0
SESSION_SUMMARY_INTERVAL_MS=600000
SESSION_SUMMARY_LOOKBACK_HOURS=26
SESSION_SUMMARY_IDLE_GAP_MS=60000
SESSION_SUMMARY_MIN_DURATION_MS=30000

# Focus-affinity hourly aggregation.
FOCUS_AFFINITY_ENABLED=0
FOCUS_AFFINITY_INTERVAL_MS=300000
FOCUS_AFFINITY_LOOKBACK_HOURS=3

# Defer-pile pruner.
DEFER_PRUNE_ENABLED=0
DEFER_PRUNE_INTERVAL_MS=21600000
DEFER_PRUNE_MAX_AGE_DAYS=30

# Cold-store archive (move >N-day-old events to disk).
COLDSTORE_INTERVAL_MS=86400000
COLDSTORE_RETENTION_DAYS=90
# Filesystem path for archive JSONL. Defaults to <cwd>/cold-store.
COLD_STORE_DIR=

# ─── Observability — Sentry (Phase C.3) ─────────────────
# Production error tracking. Empty in dev → Sentry is a no-op across every
# service. Populate in prod via Secrets Manager. The web app additionally
# reads `NEXT_PUBLIC_SENTRY_DSN` for the browser SDK; set both in prod.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Release tag stamped onto every Sentry event. Default 'unknown' is fine
# for dev; CI should set this to the git SHA at build time so source-maps
# line up with the deployed bundle.
MIAMO_RELEASE=
# Trace sampling rate (0..1). 0.1 = 10% — Sentry free-tier safe.
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
