// ─── Bookmarks / Saved Profiles ──────────────────────
model Bookmark {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation("BookmarkOwner", fields: [userId], references: [id], onDelete: Cascade)
  targetId   String
  target     User     @relation("BookmarkTarget", fields: [targetId], references: [id], onDelete: Cascade)
  targetType String   @default("profile")
  note       String   @default("")
  createdAt  DateTime @default(now())

  @@unique([userId, targetId, targetType])
  @@index([userId, createdAt])
  @@index([targetId])
}

