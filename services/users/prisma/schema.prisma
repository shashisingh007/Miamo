  grantedAt   DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([ownerId, requesterId, accessType])
  @@index([ownerId, status])
  @@index([requesterId])
}

// ─── Vibe Check ──────────────────────────────────────
model VibeCheck {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mood      String
  energy    Int      @default(3)
  topics    String   @default("[]")
  intent    String   @default("")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, active])
  @@index([mood])
}

// ─── User Activity Tracking (behavioral analytics) ──
model UserActivity {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String // view, like, pass, swipe, click, scroll, search, dwell, share, comment, match, unmatch, block, move
  targetType String   @default("profile") // profile, feed, story, video, creativity, chat, notification
  targetId   String?
  metadata   String?  @default("{}") // JSON: duration_ms, scroll_depth, search_query, etc.
  durationMs Int? // time spent on target (dwell time)
  sessionId  String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, action, targetType])
  @@index([userId, action, createdAt])
  @@index([targetType, targetId])
  @@index([action, createdAt])
  @@index([userId, targetType, createdAt])
}

// ─── v3.1 Tracking pipeline (Phase 1) ───────────────
// Hot raw events live in Redis Streams; only aggregates land in Postgres.
// All tracking tables key on uidHash (HMAC-SHA256 of userId) so an account
// delete can break the join without a full table-rewrite.

/// v3.7 Temporal Learning v2 — multi-timescale user preference history.
/// Mirrored from shared/prisma/schema.prisma. See that file for docs.
model UserPreferenceHistory {
  id          String   @id @default(uuid())
  uidHash     String
  dimension   String
  window      String
  score       Float
  sampleCount Int
  computedAt  DateTime @default(now())

  @@unique([uidHash, dimension, window])
  @@index([uidHash, computedAt])
  @@index([dimension, window])
  @@index([computedAt])
}

model ConsentEvent {
  id        String   @id @default(uuid())
  userId    String?
  did       String // device id (cookie)
  scope     String // 'analytics' | 'personalization' | 'marketing'
  granted   Boolean
  region    String? // 'IN' | 'EU' | 'US' | ...
  source    String   @default("banner") // banner | settings | api
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([did])
  @@index([userId, scope, createdAt])
}

model EventAggHourly {
  uidHash String
  evt     String
  bucket  DateTime // truncated to hour, UTC
  count   Int      @default(0)
  durSum  Int      @default(0)
  durP50  Int      @default(0)
  durP95  Int      @default(0)
  meta    Json     @default("{}")

  @@id([uidHash, evt, bucket])
  @@index([bucket])
  @@index([uidHash, bucket])
}

model EventAggDaily {
  uidHash     String
  evt         String
  day         DateTime // truncated to day, UTC
  count       Int      @default(0)
  durSum      Int      @default(0)
  uniqTargets Int      @default(0) // HLL cardinality snapshot
  meta        Json     @default("{}")

  @@id([uidHash, evt, day])
  @@index([day])
  @@index([uidHash, day])
}

model FeatureSnapshot {
  uidHash            String   @id
  computedAt         DateTime @default(now())
  chronotype         String? // morning | day | evening | night | mixed
  replyPersonaP50Ms  Int?
  replyPersonaP90Ms  Int?
  responseRate       Float?
  rageClickRate      Float?
  deadClickRate      Float?
  dwellToDecisionP50 Float?
  swipeRightRatio    Float?
  attentionProfile   String? // reader | scanner | voice-first | visual
  interestVec        Bytes? // 32 × f16
  vibeEmb            Bytes? // 64 × f16
  behaviorEmb        Bytes? // 64 × f16
  cityCenterLat      Float?
  cityCenterLng      Float?
  raw                Json     @default("{}")

  @@index([computedAt])
}

model PairCompatCache {
  aHash                 String
  bHash                 String
  computedAt            DateTime @default(now())
  interestCos           Float    @default(0)
  vibeCos               Float    @default(0)
  behaviorCos           Float    @default(0)
  magnetCos             Float    @default(0)
  cityKm                Float    @default(0)
  ageDelta              Int      @default(0)
  intentMatch           Float    @default(0)
  chronoOverlap         Float    @default(0)
  cadenceOverlap        Float    @default(0)
  priorInteractionScore Float    @default(0)
  finalScore            Float    @default(0)
  // v6 parallel score; populated by v6 PairCompatComputer behind ALGO_V6_PAIR_COMPAT_ENABLED.
  v6Score               Float?
  v6BreakdownJson       Json?    @default("{}")

  @@id([aHash, bHash])
  @@index([aHash, finalScore])
  @@index([aHash, v6Score])
  @@index([computedAt])
}

// ─── v6 — Total-state tracking ─────────────────────────
// Produced by tracking-worker at session.end. Drives Phase 5 discoverPolicy
// (window-shopping defence, zero-action recovery) and Phase 16 learner.
model SessionSummary {
  id                String   @id @default(uuid())
  uidHash           String
  sessionId         String
  startedAt         DateTime
  endedAt           DateTime
  durationMs        Int
  idleMs            Int      @default(0)
  routesVisited     Json     @default("[]")
  cardsViewed       Int      @default(0)
  swipesLeft        Int      @default(0)
  swipesRight       Int      @default(0)
  msgsSent          Int      @default(0)
  msgsRead          Int      @default(0)
  zeroActionSession Boolean  @default(false)
  windowShopping    Boolean  @default(false)
  ghostedSelf       Boolean  @default(false)
  meta              Json     @default("{}")
  createdAt         DateTime @default(now())

  @@unique([uidHash, sessionId])
  @@index([uidHash, endedAt])
  @@index([endedAt])
  @@index([uidHash, zeroActionSession])
  @@index([uidHash, windowShopping])
}

// ─── v6 — Element-level focus/dwell affinity ──────────
// Hourly rollup of (uidHash, route, elementId) -> focusCount, dwellSumMs.
// Consumed by Phase 5 feed personalisation by focusAffinityByKind.
model FocusAffinityHourly {
  uidHash    String
  route      String
  elementId  String
  bucket     DateTime
  focusCount Int      @default(0)
  dwellSumMs Int      @default(0)

  @@id([uidHash, route, elementId, bucket])
  @@index([uidHash, bucket])
  @@index([bucket])
}

// ─── v6 — Online user-learning weight profile ─────────
// One row per (active user, surface). Updated incrementally on every
// refresh / reopen. v6.5: split per surface so the bandit can carry
// independent posteriors for `discover` vs `dtm` vs other surfaces.
// See Phase 16 (Thompson-sampling bandit) for the update rules.
model UserWeightProfile {
  uidHash         String
  surface         String   @default("discover")
  weights         Json     @default("{}") // { interestsOverlap: 0.18, vibeAlignment: 0.15, ... }
  noveltyBoost    Float    @default(0.0)
  diversityBoost  Float    @default(0.0)
  explorationRate Float    @default(0.05)
  banditAlpha     Json     @default("{}")
  banditBeta      Json     @default("{}")
  lastUpdatedAt   DateTime @updatedAt
  schemaVersion   Int      @default(1)

  @@id([uidHash, surface])
  @@index([lastUpdatedAt])
  @@index([uidHash])
}

// ─── v6 — Miamo Move v3 archetype profile ─────────────
// One row per user. Computed by KMeans (4 archetypes) on send/reply patterns.
model UserMoveProfile {
  uidHash         String   @id
  archetype       String // wordsmith | voice_first | visual | fast_replier
  archetypeProbs  Json     @default("{}") // soft cluster probabilities
  avgMoveLenChars Int?
  voiceShare      Float? // fraction of moves that are voice notes
  mediaShare      Float? // fraction of moves that include media
  p50ReplyMinutes Int?
  lastComputedAt  DateTime @default(now())
  schemaVersion   Int      @default(1)

  @@index([archetype])
  @@index([lastComputedAt])
}

// ─── v6.5 — Safety + match-state daily aggregate ─────
// One row per (uidHash, surface, kind, day). Surfaces and kinds:
//   surface ∈ 'discover' | 'matches' | 'messages' | 'profile' | 'dtm'
//   kind    ∈ 'block' | 'report' | 'unmatch' | 'hold' | 'unhold'
// Consumed by the v6.5 learner loop as hard-negative (block/report) or
// neutral (hold/unhold) signals, separate from soft swipe regret.
model SafetyAgg {
  uidHash String
  surface String
  kind    String
  day     DateTime // truncated to day, UTC
  count   Int      @default(0)
  meta    Json     @default("{}") // optional: { targets: { tHash: count, ...capped 64 } }

  @@id([uidHash, surface, kind, day])
  @@index([day])
  @@index([uidHash, day])
  @@index([uidHash, kind, day])
}

// ─── v6.5 — First-move reply outcomes ────────────────
// One row per (aHash, bHash, sentAt). Reconciled twice a day by the
// firstMoveOutcome worker by joining msg.send (firstMove=true) with
// msg.read on the same pair within 24h. Used by Miamo Move v3 to train
// `UserMoveProfile.byKind[kind].replied`.
model FirstMoveOutcome {
  aHash     String
  bHash     String
  sentAt    DateTime
  kind      String // 'text' | 'voice' | 'media' | 'reaction'
  replied   Boolean  @default(false)
  replyMs   Int? // null until replied; ms between send and recipient's first read
  archetype String? // recipient archetype at send time (cached)
  meta      Json     @default("{}")
  createdAt DateTime @default(now())

  @@id([aHash, bHash, sentAt])
  @@index([aHash, sentAt])
  @@index([bHash, sentAt])
  @@index([sentAt, replied])
}

// ─── v6.6 — See-later pile (Discover + DTM) ─────────
// One row per deferred item. `surface` discriminates the pile so the same
// table serves Discover ("see this profile later") and DTM ("answer this
// question later"). When the user resolves the deferral the row is updated
// in place (resolvedAt + resolvedAction). Rows older than 30 days are
// pruned by tracking-worker. Consumed by:
//   - learnerLoop (deferral as soft-negative; resolution as attribution)
//   - discoverPolicy (skipped pile UI, "view skipped profiles")
//   - dtmV6 (defer-then-revise question reordering)
model DeferredItem {
  id             String    @id @default(uuid())
  uidHash        String
  surface        String // 'discover' | 'dtm'
  targetId       String // tid for discover, qid for dtm
  topic          String? // dtm only — the topic the qid belongs to
  batchId        String? // optional analytics tag for the batch it came from
  reason         String? // 'not_now' | 'thinking' | 'unsure' | 'other'
  deferredAt     DateTime  @default(now())
  viewedAt       DateTime? // first time the user opened it from the pile
  resolvedAt     DateTime? // when the deferral was resolved
  resolvedAction String? // 'like' | 'pass' | 'super_like' | 'see_later' | 'answered' | 'skipped'
  meta           Json      @default("{}")

  @@unique([uidHash, surface, targetId])
  @@index([uidHash, surface, deferredAt])
  @@index([uidHash, surface, resolvedAt])
  @@index([deferredAt])
}

// ─── User Data (generic feature persistence) ────────
model UserData {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // love_language_result, date_plan, date_idea_saved, compatibility_result, search_history, premium_interest
  data      Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, type])
  @@index([userId, type, createdAt])
}

// ─── DTM Chat Messages (persistent) ─────────────────
model DtmMessage {
  id          String   @id @default(uuid())
  senderId    String
  sender      User     @relation("DtmSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipientId String
  recipient   User     @relation("DtmRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  message     String
  type        String   @default("text")
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([senderId, recipientId, createdAt])
  @@index([recipientId, read])
}

// ─── v3.2 — Showcase (replaces Creativity) ──────────────
model ShowcaseItem {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation("ShowcaseAuthor", fields: [userId], references: [id], onDelete: Cascade)
  category        String
  type            String // link | image | text | voice
  title           String   @db.VarChar(120)
  body            String?  @db.VarChar(300)
  url             String?
  imageUrl        String?
  ogImageCached   String?
  voiceUrl        String?
  voiceDurationMs Int?
  bytes           Int      @default(0)
  pinned          Boolean  @default(false)
  moveCount       Int      @default(0)
  matchCount      Int      @default(0)
  visibility      String   @default("everyone") // everyone | matches | private
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, pinned])
  @@index([category, createdAt])
}

// ─── v3.2 — Access Control ──────────────────────────────
model AccessRequest {
  id         String    @id @default(uuid())
  fromUserId String
  fromUser   User      @relation("AccessRequestFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String
  toUser     User      @relation("AccessRequestTo", fields: [toUserId], references: [id], onDelete: Cascade)
  field      String // photos|phone|family|income|kundli|lastName|exactCity|socials|email
  status     String    @default("pending") // pending|approved|denied|revoked|expired
  message    String?   @db.VarChar(500)
  createdAt  DateTime  @default(now())
  decidedAt  DateTime?
  expiresAt  DateTime?

  @@unique([fromUserId, toUserId, field])
  @@index([toUserId, status])
  @@index([fromUserId, status])
}

// ─── Spotlight (added in Creativity v2) ───
model SpotlightLedger {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  delta     Int
  reason    String
  refId     String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([reason])
}

model SpotlightAward {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation("SpotlightAwardUser", fields: [userId], references: [id], onDelete: Cascade)
  kind      String
  itemId    String?
  meta      Json?
  createdAt DateTime @default(now())

  @@unique([userId, kind])
  @@index([kind])
}

// ─── v3.6.0 — Exposure Ledger (earned visibility) ───
model ExposureLedger {
  id         String   @id @default(uuid())
  uidHash    String // HMAC-hashed userId
  surface    String // 'discover' | 'dtm' | 'aiMatch'
  deltaSlots Int // +N earned, -N spent
  reason     String // 'sticky_like' | 'message_reply' | 'dtm_completed' | 'bio_expand' | 'view_long' | 'move_accepted' | 'rage_like_zero' | 'admin_grant' | 'top10_filled' | 'fairness_inject'
  refId      String?
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([uidHash, surface, createdAt])
  @@index([reason])
  @@index([createdAt])
}

model ExposureCredit {
  uidHash     String
  surface     String
  slotsEarned Int      @default(0)
  slotsSpent  Int      @default(0)
  lastTopUp   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@id([uidHash, surface])
  @@index([surface, lastTopUp])
}

model WeeklyTopMatch {
  id         String   @id @default(uuid())
  uidHash    String
  weekIso    String // e.g. "2026W26"
  rank       Int // 1..10
  targetHash String // candidate uidHash
  computedAt DateTime @default(now())

  @@unique([uidHash, weekIso, rank])
  @@index([uidHash, weekIso])
  @@index([weekIso])
}

model FamilyBriefShare {
  id          String   @id @default(uuid())
  userId      String
  token       String   @unique // 22-char base64url, embedded in URL
  format      String // 'pdf' | 'image' | 'text'
  generatedAt DateTime @default(now())
  expiresAt   DateTime // generatedAt + 7d
  viewCount   Int      @default(0)
  trackViews  Boolean  @default(false) // opt-in by user

  @@index([userId, generatedAt])
  @@index([expiresAt])
  @@index([token])
}
