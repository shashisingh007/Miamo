{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "noEmit": true
  },
  "include": ["src/**/*", "*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "prisma",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/*.integration.test.ts",
    "src/__tests__/**",
    "src/algo/__tests__/**",
    "src/track/__tests__/**",
    "src/experiments/**"
  ]
}
